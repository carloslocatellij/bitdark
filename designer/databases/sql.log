CREATE TABLE "auth_group"(
    "id" INTEGER PRIMARY KEY AUTOINCREMENT,
    "role" CHAR(512),
    "description" TEXT
);
success!
timestamp: 2019-01-31T13:21:03.693450
CREATE TABLE "auth_membership"(
    "id" INTEGER PRIMARY KEY AUTOINCREMENT,
    "user_id" INTEGER REFERENCES "auth_user" ("id") ON DELETE CASCADE  ,
